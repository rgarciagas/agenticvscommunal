    "\n",
    "# Gendered wording in job advertisements\n",
    "# Agentic (masculine-coded) vs communal (feminine-coded) language\n",
    "# across male-dominated and female-dominated job functions.\n",
    "#\n",
    "# Pipeline: load data -> score each ad with the Gaucher et al. (2011)\n",
    "# gendered word stems -> compare groups with t-tests and ANOVA ->\n",
    "# effect sizes -> figures and a results table.\n",
    "#SETUP\n",
    "# 1. Install packages:\n",
    "#      pip install pandas scipy numpy matplotlib\n",
    "# 2. Get the dataset (EMSCAD, 17,880 real job ads). Either download\n",
    "#    \"fake_job_postings.csv\" from Kaggle (Real/Fake Job Posting\n",
    "#    Prediction) or clone a public mirror, e.g.:\n",
    "#      git clone https://github.com/FelixLuciano/Fake-JobPosting-Prediction\n",
    "#    then set DATA_PATH below to the csv location.\n",
    "#Set OUT_DIR to where you want it to be saved (this code creates a separate folder)\n",
    "\n",
    "import re\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib\n",
    "matplotlib.use(\"Agg\")\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy import stats\n",
    "\n",
    "import os\n",
    "\n",
    "OUT_DIR = \"outputs\"\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "\n",
    "# ----- paths: edit these to match your machine ---------------\n",
    "DATA_PATH = \"https://raw.githubusercontent.com/FelixLuciano/Fake-JobPosting-Prediction/main/src/dataset/fake_job_postings.csv\"\n",
    "\n",
    "import os\n",
    "OUT_DIR = \"outputs\"\n",
    "os.makedirs(OUT_DIR, exist_ok=True)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1. Gendered word stem lists (Gaucher et al., 2011), taken verbatim\n",
    "#    from Matfield's gender-decoder. Embedded here so the script is\n",
    "#    self-contained (no external wordlists.py import needed). Words are\n",
    "#    stems: a token counts as coded if it STARTS WITH one of these.\n",
    "# ------------------------------------------------------------\n",
    "masculine_stems = [\n",
    "    \"active\", \"adventurous\", \"aggress\", \"ambitio\", \"analy\", \"assert\",\n",
    "    \"athlet\", \"autonom\", \"battle\", \"boast\", \"challeng\", \"champion\",\n",
    "    \"compet\", \"confident\", \"courag\", \"decid\", \"decision\", \"decisive\",\n",
    "    \"defend\", \"determin\", \"domina\", \"dominant\", \"driven\", \"fearless\",\n",
    "    \"fight\", \"force\", \"greedy\", \"head-strong\", \"headstrong\", \"hierarch\",\n",
    "    \"hostil\", \"impulsive\", \"independen\", \"individual\", \"intellect\",\n",
    "    \"lead\", \"logic\", \"objective\", \"opinion\", \"outspoken\", \"persist\",\n",
    "    \"principle\", \"reckless\", \"self-confiden\", \"self-relian\",\n",
    "    \"self-sufficien\", \"selfconfiden\", \"selfrelian\", \"selfsufficien\",\n",
    "    \"stubborn\", \"superior\", \"unreasonab\",\n",
    "]  # 52 agentic stems\n",
    "\n",
    "feminine_stems = [\n",
    "    \"agree\", \"affectionate\", \"child\", \"cheer\", \"collab\", \"commit\",\n",
    "    \"communal\", \"compassion\", \"connect\", \"considerate\", \"cooperat\",\n",
    "    \"co-operat\", \"depend\", \"emotiona\", \"empath\", \"feel\", \"flatterable\",\n",
    "    \"gentle\", \"honest\", \"interpersonal\", \"interdependen\", \"interpersona\",\n",
    "    \"inter-personal\", \"inter-dependen\", \"inter-persona\", \"kind\",\n",
    "    \"kinship\", \"loyal\", \"modesty\", \"nag\", \"nurtur\", \"pleasant\", \"polite\",\n",
    "    \"quiet\", \"respon\", \"sensitiv\", \"submissive\", \"support\", \"sympath\",\n",
    "    \"tender\", \"together\", \"trust\", \"understand\", \"warm\", \"whin\",\n",
    "    \"enthusias\", \"inclusive\", \"yield\", \"share\", \"sharin\",\n",
    "]  # 50 communal stems\n",
    "\n",
    "exceptions = {\"sharepoint\"}  # \"share\" stem but not actually communal\n",
    "\n",
    "print(\"masculine (agentic) stems:\", len(masculine_stems))\n",
    "print(\"feminine (communal) stems:\", len(feminine_stems))\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2. Load the job postings (EMSCAD) and keep only legitimate ads.\n",
    "# ------------------------------------------------------------\n",
    "df = pd.read_csv(DATA_PATH)\n",
    "\n",
    "# keep genuine postings only (fraudulent == 0); drop scam ads\n",
    "df = df[df[\"fraudulent\"] == 0].copy()\n",
    "\n",
    "# need a job function label and some description text\n",
    "df = df[df[\"function\"].notna()].copy()\n",
    "df = df[df[\"description\"].notna()].copy()\n",
    "\n",
    "# build the ad text: title + description + requirements (when present)\n",
    "df[\"requirements\"] = df[\"requirements\"].fillna(\"\")\n",
    "df[\"title\"] = df[\"title\"].fillna(\"\")\n",
    "df[\"ad_text\"] = (df[\"title\"] + \" \" + df[\"description\"] + \" \" + df[\"requirements\"])\n",
    "\n",
    "print(\"\\nlegitimate postings with a function label:\", len(df))\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 3. Score every ad: count agentic and communal coded words.\n",
    "#    A word is \"coded\" if it starts with one of the stems\n",
    "#    (this is the standard gender-decoder matching rule).\n",
    "# ------------------------------------------------------------\n",
    "masc_counts = []\n",
    "fem_counts = []\n",
    "total_tokens = []\n",
    "\n",
    "for text in df[\"ad_text\"]:\n",
    "    # lowercase and pull out word tokens\n",
    "    words = re.findall(r\"[a-z][a-z\\-]+\", str(text).lower())\n",
    "    n = len(words)\n",
    "    m = 0\n",
    "    f = 0\n",
    "    for word in words:\n",
    "        if word in exceptions:\n",
    "            continue\n",
    "        # agentic?\n",
    "        if any(word.startswith(stem) for stem in masculine_stems):\n",
    "            m += 1\n",
    "        # communal?\n",
    "        if any(word.startswith(stem) for stem in feminine_stems):\n",
    "            f += 1\n",
    "    masc_counts.append(m)\n",
    "    fem_counts.append(f)\n",
    "    total_tokens.append(n)\n",
    "\n",
    "df[\"n_tokens\"] = total_tokens\n",
    "df[\"masc_n\"] = masc_counts\n",
    "df[\"fem_n\"] = fem_counts\n",
    "\n",
    "# drop very short / empty ads so proportions are stable\n",
    "df = df[df[\"n_tokens\"] >= 30].copy()\n",
    "\n",
    "# normalise to \"coded words per 100 words\" so ad length doesn't drive results\n",
    "df[\"masc_per100\"] = df[\"masc_n\"] / df[\"n_tokens\"] * 100.0\n",
    "df[\"fem_per100\"] = df[\"fem_n\"] / df[\"n_tokens\"] * 100.0\n",
    "# difference score: positive = more agentic than communal\n",
    "df[\"diff\"] = df[\"masc_per100\"] - df[\"fem_per100\"]\n",
    "\n",
    "print(\"postings after length filter:\", len(df))\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 4. Assign each function to a workforce-gender group.\n",
    "#    Classification follows occupational sex composition\n",
    "#    (U.S. Bureau of Labor Statistics, Current Population Survey):\n",
    "#    engineering and IT are male-dominated; administrative support,\n",
    "#    health-care support, HR and education are female-dominated.\n",
    "# ------------------------------------------------------------\n",
    "male_dominated = [\"Engineering\", \"Information Technology\"]\n",
    "female_dominated = [\"Administrative\", \"Health Care Provider\",\n",
    "                    \"Human Resources\", \"Education\"]\n",
    "\n",
    "df[\"group\"] = np.where(df[\"function\"].isin(male_dominated), \"Male-dominated\",\n",
    "              np.where(df[\"function\"].isin(female_dominated), \"Female-dominated\",\n",
    "                       \"Other\"))\n",
    "\n",
    "male_grp = df[df[\"group\"] == \"Male-dominated\"]\n",
    "female_grp = df[df[\"group\"] == \"Female-dominated\"]\n",
    "\n",
    "print(\"\\nMale-dominated ads:\", len(male_grp))\n",
    "print(\"Female-dominated ads:\", len(female_grp))\n",
    "\n",
    "# 5. PRIMARY TEST A -- agentic wording across the two groups\n",
    "\n",
    "a = male_grp[\"masc_per100\"].values\n",
    "b = female_grp[\"masc_per100\"].values\n",
    "\n",
    "# check equal-variance assumption first\n",
    "lev_stat, lev_p = stats.levene(a, b)\n",
    "# Welch's t-test (does not assume equal variances) -- safe default\n",
    "t_masc, p_masc = stats.ttest_ind(a, b, equal_var=False)\n",
    "df_masc = len(a) + len(b) - 2  # report classical df for the write-up\n",
    "\n",
    "# Cohen's d with pooled SD\n",
    "sd_pooled = np.sqrt(((len(a)-1)*a.var(ddof=1) + (len(b)-1)*b.var(ddof=1)) /\n",
    "                    (len(a)+len(b)-2))\n",
    "d_masc = (a.mean() - b.mean()) / sd_pooled\n",
    "\n",
    "# non-parametric robustness check\n",
    "u_masc, up_masc = stats.mannwhitneyu(a, b, alternative=\"two-sided\")\n",
    "\n",
    "print(\"\\n--- AGENTIC (masculine-coded) words per 100 ---\")\n",
    "print(f\"Male-dominated:   M={a.mean():.3f}, SD={a.std(ddof=1):.3f}, n={len(a)}\")\n",
    "print(f\"Female-dominated: M={b.mean():.3f}, SD={b.std(ddof=1):.3f}, n={len(b)}\")\n",
    "print(f\"Levene p={lev_p:.4f}\")\n",
    "print(f\"Welch t({df_masc})={t_masc:.3f}, p={p_masc:.3e}, Cohen's d={d_masc:.3f}\")\n",
    "print(f\"Mann-Whitney U={u_masc:.0f}, p={up_masc:.3e}\")\n",
    "\n",
    "# 6. PRIMARY TEST B -- communal wording across the two groups\n",
    "\n",
    "a2 = male_grp[\"fem_per100\"].values\n",
    "b2 = female_grp[\"fem_per100\"].values\n",
    "\n",
    "lev_stat2, lev_p2 = stats.levene(a2, b2)\n",
    "t_fem, p_fem = stats.ttest_ind(a2, b2, equal_var=False)\n",
    "sd_pooled2 = np.sqrt(((len(a2)-1)*a2.var(ddof=1) + (len(b2)-1)*b2.var(ddof=1)) /\n",
    "                     (len(a2)+len(b2)-2))\n",
    "d_fem = (a2.mean() - b2.mean()) / sd_pooled2\n",
    "u_fem, up_fem = stats.mannwhitneyu(a2, b2, alternative=\"two-sided\")\n",
    "\n",
    "print(\"\\n--- COMMUNAL (feminine-coded) words per 100 ---\")\n",
    "print(f\"Male-dominated:   M={a2.mean():.3f}, SD={a2.std(ddof=1):.3f}, n={len(a2)}\")\n",
    "print(f\"Female-dominated: M={b2.mean():.3f}, SD={b2.std(ddof=1):.3f}, n={len(b2)}\")\n",
    "print(f\"Levene p={lev_p2:.4f}\")\n",
    "print(f\"Welch t={t_fem:.3f}, p={p_fem:.3e}, Cohen's d={d_fem:.3f}\")\n",
    "print(f\"Mann-Whitney U={u_fem:.0f}, p={up_fem:.3e}\")\n",
    "\n",
    "\n",
    "# 7. SECONDARY TEST one-way ANOVA across six individual\n",
    "#    functions on the difference score (agentic minus communal).\n",
    "\n",
    "focus_functions = [\"Engineering\", \"Information Technology\", \"Education\",\n",
    "                   \"Administrative\", \"Health Care Provider\", \"Human Resources\"]\n",
    "anova_df = df[df[\"function\"].isin(focus_functions)].copy()\n",
    "\n",
    "groups_for_anova = [anova_df[anova_df[\"function\"] == fn][\"diff\"].values\n",
    "                    for fn in focus_functions]\n",
    "F_stat, F_p = stats.f_oneway(*groups_for_anova)\n",
    "\n",
    "# partial eta squared = SS_between / (SS_between + SS_within)\n",
    "grand_mean = anova_df[\"diff\"].mean()\n",
    "ss_between = sum(len(g) * (g.mean() - grand_mean)**2 for g in groups_for_anova)\n",
    "ss_within = sum(((g - g.mean())**2).sum() for g in groups_for_anova)\n",
    "eta_sq = ss_between / (ss_between + ss_within)\n",
    "df_between = len(focus_functions) - 1\n",
    "df_within = len(anova_df) - len(focus_functions)\n",
    "\n",
    "print(\"\\n--- ANOVA across six functions (difference score) ---\")\n",
    "print(f\"F({df_between},{df_within})={F_stat:.3f}, p={F_p:.3e}, \"\n",
    "      f\"partial eta^2={eta_sq:.3f}\")\n",
    "\n",
    "\n",
    "# 8. Build a clean results table and save it.\n",
    "\n",
    "summary = (df[df[\"function\"].isin(focus_functions)]\n",
    "           .groupby(\"function\")\n",
    "           .agg(n=(\"diff\", \"size\"),\n",
    "                masc_mean=(\"masc_per100\", \"mean\"),\n",
    "                masc_sd=(\"masc_per100\", \"std\"),\n",
    "                fem_mean=(\"fem_per100\", \"mean\"),\n",
    "                fem_sd=(\"fem_per100\", \"std\"),\n",
    "                diff_mean=(\"diff\", \"mean\"))\n",
    "           .reindex(focus_functions)\n",
    "           .round(3))\n",
    "summary.to_csv(OUT_DIR + \"/results_by_function.csv\")\n",
    "print(\"\\nPer-function summary:\\n\", summary)\n",
    "\n",
    "\n",
    "# 9. FIGURE 1 -- grouped bar chart, two groups, agentic vs communal\n",
    "\n",
    "def ci95(x):\n",
    "    return 1.96 * np.std(x, ddof=1) / np.sqrt(len(x))\n",
    "\n",
    "labels = [\"Agentic\\n(masculine-coded)\", \"Communal\\n(feminine-coded)\"]\n",
    "male_means = [a.mean(), a2.mean()]\n",
    "female_means = [b.mean(), b2.mean()]\n",
    "male_err = [ci95(a), ci95(a2)]\n",
    "female_err = [ci95(b), ci95(b2)]\n",
    "\n",
    "x = np.arange(len(labels))\n",
    "width = 0.35\n",
    "fig, ax = plt.subplots(figsize=(7, 4.5))\n",
    "ax.bar(x - width/2, male_means, width, yerr=male_err, capsize=4,\n",
    "       label=f\"Male-dominated (n={len(a)})\", color=\"#4C72B0\")\n",
    "ax.bar(x + width/2, female_means, width, yerr=female_err, capsize=4,\n",
    "       label=f\"Female-dominated (n={len(b)})\", color=\"#C44E52\")\n",
    "ax.set_ylabel(\"Coded words per 100 words\")\n",
    "ax.set_title(\"Gendered wording by workforce-gender group\")\n",
    "ax.set_xticks(x); ax.set_xticklabels(labels)\n",
    "ax.legend()\n",
    "# significance star for the agentic comparison\n",
    "ymax = max(male_means[0], female_means[0]) + max(male_err[0], female_err[0])\n",
    "ax.plot([x[0]-width/2, x[0]+width/2], [ymax*1.08]*2, color=\"black\", lw=1)\n",
    "ax.text(x[0], ymax*1.10, \"***\", ha=\"center\", va=\"bottom\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(OUT_DIR + \"/figure1_groups.png\", dpi=200)\n",
    "plt.close()\n",
    "\n",
    "\n",
    "# 10. FIGURE 2 -- difference score across the six functions\n",
    "\n",
    "order = summary.sort_values(\"diff_mean\", ascending=False)\n",
    "colors = [\"#4C72B0\" if fn in male_dominated else \"#C44E52\"\n",
    "          for fn in order.index]\n",
    "diff_err = [ci95(anova_df[anova_df[\"function\"] == fn][\"diff\"].values)\n",
    "            for fn in order.index]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 4.5))\n",
    "ax.barh(order.index, order[\"diff_mean\"], xerr=diff_err, capsize=3, color=colors)\n",
    "ax.axvline(0, color=\"black\", lw=0.8)\n",
    "ax.set_xlabel(\"Agentic minus communal words per 100  (>0 = more agentic)\")\n",
    "ax.set_title(\"Net agentic wording by job function\")\n",
    "# manual legend\n",
    "from matplotlib.patches import Patch\n",
    "ax.legend(handles=[Patch(color=\"#4C72B0\", label=\"Male-dominated\"),\n",
    "                   Patch(color=\"#C44E52\", label=\"Female-dominated\")],\n",
    "          loc=\"lower right\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(OUT_DIR + \"/figure2_functions.png\", dpi=200)\n",
    "plt.close()\n",
    "\n",
    "print(\"\\nSaved: figure1_groups.png, figure2_functions.png, results_by_function.csv\")"
   ]
